{
    "name": "drupal/legacy-project",
    "description": "Project template for Drupal 10 projects with composer following drupal/drupal layout",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^2.0",
        "drupal/address": "^2.0",
        "drupal/ai": "^1.1@beta",
        "drupal/asset_injector": "^2.0",
        "drupal/commerce": "^2.37",
        "drupal/commerce_paypal": "^1.8",
        "drupal/commerce_simple_stock": "^1.0",
        "drupal/commerce_stripe": "^1.3",
        "drupal/composer_deploy": "^1.10",
        "drupal/core-composer-scaffold": "10.6.3",
        "drupal/core-project-message": "10.6.3",
        "drupal/core-recommended": "10.6.3",
        "drupal/core-vendor-hardening": "^10.0",
        "drupal/field_timer": "^2.0",
        "drupal/inline_entity_form": "^1.0@RC",
        "drupal/mailsystem": "^4.0",
        "drupal/mysql57": "^1.0",
        "drupal/search_api": "^1.38",
        "drupal/seven": "^1.0",
        "drupal/symfony_mailer": "^1.0",
        "drupal/token_filter": "^2.2",
        "drupal/twig_tweak": "^3.4",
        "drupal/views_data_export": "^1.0",
        "drupal/webform": "^6.3",
        "drush/drush": "^12.4"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "drupal/core-vendor-hardening": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "./"
            }
        },
        "installer-paths": {
            "core": [
                "type:drupal-core"
            ],
            "libraries/{$name}": [
                "type:drupal-library"
            ],
            "modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        }
    }
}
