# ==============================================================================
# Environment Variables for Drupal — nasande.cg
# ==============================================================================
# Copy this file to .env (or set in your hosting environment)
# These variables are read by settings.php to configure the database connection.
#
# On cPanel, set these in .htaccess with:
#   SetEnv DRUPAL_DB_NAME nasacdka_nasande
#   SetEnv DRUPAL_DB_USER nasacdka_nasande
#   SetEnv DRUPAL_DB_PASS your_password_here
#   SetEnv DRUPAL_DB_HOST localhost
# ==============================================================================

# Database
DRUPAL_DB_NAME=nasacdka_nasande
DRUPAL_DB_USER=nasacdka_nasande
DRUPAL_DB_PASS=CHANGE_ME
DRUPAL_DB_HOST=localhost
DRUPAL_DB_PORT=

# Environment
DRUPAL_ENV=production

# Hash salt (keep same across all environments)
# DRUPAL_HASH_SALT=DVpOmJkgfbmnCavSnLkslhkyYLgPXRMQxz_W2obdto3_nhbj8kHyvwpHnJkxzn2fNWBYwmnAgA

# Private file path (production)
# DRUPAL_PRIVATE_PATH=/home/nasacdka/pharmaciemayamaya.cg/private
